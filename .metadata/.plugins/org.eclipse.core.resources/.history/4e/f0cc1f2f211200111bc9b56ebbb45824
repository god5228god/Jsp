<script type="text/javascript">
	function searchEmoji()
	{
		// Test032.html 창 열기
		window.open("Test032.html", "test", "width=500, height=400");
	}
</script>
</head>
<body>
<div class="searchWrap">
	<h2>특수문자 검색</h2>
	<form>
		<input type="text" id="emoji" readonly="readonly"  class="txt" />
