<%@ page contentType="text/html; charset=UTF-8"%>
<%
	
	String year = request.getParameter("yearBox");
	String month = request.getParameter("monthBox");
	int y = 0;
	int m = 0;
	int total = 0;
	int[] eDate =  {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};
	int startDay = 0;
	int endDay = 0;
	
	java.util.Calendar cal = java.util.Calendar.getInstance();
	int nowYear = cal.get(java.util.Calendar.YEAR);
	int nowMonth = cal.get(java.util.Calendar.MONTH) + 1;
	
	int year1 = (year == null)? nowYear : y;
	int month1 = (month == null)? nowMonth: m;
	
	
	
	try
	{
		y = Integer.parseInt(year);
		m = Integer.parseInt(month);
		
		total = 0 ;
		
		total = (y-1) * 365 + (y-1)/4 - (y-1)/100 + (y-1)/400;
				
		if((y%4 == 0 && y%100 !=0) || (y%400 == 0)){
			eDate[1] = 29;
		}
		
		for(int i = 0; i<m-1; i++)
		{
			total += eDate[i];
		}
		total += 1;
		
		startDay = total % 7 ;
		endDay = eDate[m-1];
		
		
		
	}catch(Exception e)
	{
		System.out.println(e.toString());
	}


%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>SendAndReceive11.jsp</title>
<link rel="stylesheet" type="text/css" href="css/main.css" />
<style type="text/css">
	.calendar{margin-top: 20px;}
	table{border-collapse: collapse;  }
	tr>*{text-align: center; padding: 5px; width: 15px; height: 15px;}
	.title{font-size: 18px; font-weight: bold; display:inline-block; width: 200px; text-align: center;}
</style>
<script type="text/javascript">

	function formChange(obj){
		obj.submit();	
		addCalendar();
	}

</script>
</head>
<body>
<div>
	<h1>JSP를 이용한 데이터 송수신 실습 11</h1>
	<p>SendAndReceive11.jsp● → SendAndReceive11.jsp●</p>
	<hr />
</div>

<!-- 
	○ 데이터 송수신 실습
	
	  - 연도와 월을 입력받아 해당 연월의 달력을 화면에 출력하는 JSP 페이지를 구성한다.
	  
	  - 단, submit 버튼 없이 이벤트 처리를 할 수 있도록 한다.
	  
	  - 전송한 내용을 수신하여 출력해주는 형태의 페이지로 구성한다.
	  
	  - 연도 구성은 현재 연도를 기준으로 이전 10년, 이후 10년으로 구성한다.
	    (기본적으로 만년 달력을 구성하는데, 현재의 연, 월을 달력 객체를 활용할 수 있도록 한다.)

	  - 월 구성은 1월부터 12월까지로 한다.
	  
	  페이지 레이아웃
	  ---------------------------------------------
	   2016			 1	
	  	 :			 :
	  [2026 ▼] 년 [ 3 ▼] 월
	  	 :			 :
	   2036			12
	  
	  
	  ----------------------------
	  ---- 해당 년 월의 달력 -----
	  ----------------------------
	  ----------------------------
	  
	  ---------------------------------------------
	  
	  - 연도 select나 월 select의 내용이 변화되면
	    해당 연 월의 달력을 출력하주는 형태의 페이지로 구성한다.
	    
	    - 사용자 최초 요청 주소
	      http://localhost:3306/WebApp06/SendAndReceive11.jsp
	      
	   - 물리적 파일 구성
	     ·SendAndReceive11.jsp
	
 -->
<div>
	<form method="get">
		<div class="inputWrap">
			<select name="yearBox" id="yearBox" onchange="formChange(this.form)">
			<%
				int checkYear = nowYear;
				for(int i = checkYear - 10; i<= checkYear + 10; i++)
				{
					if(i == checkYear)
					{
			%>
						<option value="<%= i%>" selected="selected"><%= i %></option>
			<%
					}
			%>
				<option value="<%= i%>"><%= i %></option>
			<%
				}
			%>
			</select>년
			<select name="monthBox" id="monthBox" onchange="formChange(this.form)">
			<%
				int checkMonth = nowMonth;
				for(int i = 1; i<= 12; i++){
					if(i== nowMonth){
			%>
					<option value="<%= i%>" selected="selected"><%=i %></option>
			<%
					}
			%>
				<option value="<%= i%>"><%=i %></option>
			<%
				}
			%>
			</select>월
		</div>
	</form>
</div>
<div class="calendar">
<p class="title"><span><%= year %></span>년 <span><%= month %></span>월</p>
	<table border="1" id="tableBox">
		<tr>
			<th>일</th>
			<th>월</th>
			<th>화</th>
			<th>수</th>
			<th>목</th>
			<th>금</th>
			<th>토</th>
		</tr>
		<tr>
		<%
		for(int i = 0; i< startDay; i++)
		{
			out.print("<td></td>");
		}
		
		int cnt = startDay;
		for(int i = 1; i<= endDay; i++){
			out.print("<td>"+ i +"</td>");
			cnt++;
			if(cnt%7 == 0){
				out.print("</tr><tr>");
			}
		}
		int remain = (startDay + endDay) % 7 ;
		if(remain !=0){
			for(int i = 0 ; i< 7-remain; i++)
			{
				out.print("<td></td>");
			}
		}
		
		%>
		</tr>
	</table>
</div>

</body>
</html>