<%@ page contentType="text/html; charset=UTF-8"%>
<%
	// 스크립릿 영역
	
	String str = request.getParameter("dan");
	String result = "";
	try
	{
		int dan = Integer.parseInt(str);
		
		for(int i=1; i<10; i++)
		{
			int res = dan * i;
			result = dan + " * " + i + "= " + res +"<br>";
		}
		
		
	}
	catch (Exception e)
	{
		System.out.println(e.toString());
		
		getServletContext().log("오류: "+e.toString());
	
	}

%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Receive04.jsp</title>
<link rel="stylesheet" type="text/css" href="css/main.css" />
</head>
<body>
<div>
	입력하신 단은 <span><%= str %></span>단 입니다.<br>
	<span><%= result %></span>
</div>
</body>
</html>