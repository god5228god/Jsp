// 현재
// Test005 클래스는 일반 자바 클래스

// 이를 서블릿(Servlet)으로 구성하는 방법

// - Servlet 인터페이스 구현 	→ implements Servlet
// - GenericServlet 클래스 상속 → extends GenericServlet
// - HttpServlet 클래스 상속 	→ extends HttpServlet

package com.svt;

import java.io.IOException;

import javax.servlet.ServletException;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

// public class Test005
//			↓
public class Test005 extends HttpServlet
{
	private static final long serialVersionUID = 1L;

	// 사용자의 http 프로토콜 요청이 GET 방식일 경우 호출되는 메소드
	@Override
	protected void doGet(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException
	{
		//GET 방식의 요청에 대해 처리하는 코드
		process(request, response);
	}

	// 사용자의 http 프로토콜 요청이 POST 방식일 경우 호출되는 메소드
	@Override
	protected void doPost(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException
	{
		//POST 방식의 요청에 대해 처리하는 코드
		process(request, response);
	}

	// 사용자 정의 메소드
	protected void process(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException
	{
		// GET 방식이든 POST 방식이든
		// 어떤 방식의 요청에도 모두 처리할 수 잇는 사용자 정의 메소드
		
		// ※ request → 요청 객체
		
		// 클라이언트로부터 데이터 수신
		String id = request.getParameter("userId"); 	//"superman"
		String pwd = request.getParameter("userPwd"); 	//"java004"
	}

}
















