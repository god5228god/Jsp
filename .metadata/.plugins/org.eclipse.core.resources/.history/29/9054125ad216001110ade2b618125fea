<%@ page contentType="text/html; charset=UTF-8"%>
<%
	
	//이전 페이지(Send08.jsp)로부터 넘어온 데이터 수신

	request.setCharacterEncoding("UTF-8");

	String id = request.getParameter("userId");
	String pw = request.getParameter("userPw");
	String name = request.getParameter("userName");
	String tel = request.getParameter("userTel");
	String gender = request.getParameter("userGender");
	String city = request.getParameter("userCity");
	
	String[] userSubject = request.getParameterValues("userSubject");
	String subjects = "";
	
	if(userSubject != null){		
		for(String item:userSubject){
			subjects += "[" + item +"] ";
			
		}
	}
	
%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Receive07.jsp</title>
<link rel="stylesheet" type="text/css" href="css/main.css" />
<style type="text/css">

</style>
</head>
<body>
<div>
	<h1>JSP를 이용한 데이터 송수신 실습 08</h1>
	<p>Send08.jsp○ → Receive08.jsp●</p>
	<hr />
</div>
<div>
	<p>아이디: <span><%= id %></span></p>
	<p>비밀번호: <span><%= pw %></span></p>
	<p>이름: <span><%= name %></span></p>
	<p>전화번호: <span><%= tel %></span></p>
	<p>성별: <span><%= gender %></span></p>
	<p>지역: <span><%= city %></span></p>
	<p>수강과목: <span><%= subjects %></span></p>
</div>
</body>
</html>