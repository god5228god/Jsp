<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Test031.html</title>
<style type="text/css">
	* {	padding: 0; margin: 0; font-size: 16px; color: #333;}
	.btn{
			position: relative; top: 2px; left: 210px;
			width: 80px; height: 30px; font-weight: bold;
			border: none; border-radius: 7px;
