	// 모범 답안
	// 선택할 수 있는 아이스크림의 갯수
	let cnt = 0;
	// 사용자가 선택한 아이스크림의 갯수
	let userCnt = 0;
	
	// 라디오 버튼 클릭 시 호출되는 함수
	function countSet(val){
		// alert(val+"확인");
		
		cnt = parseInt(val);
		
		alert("선택할 수 있는 아이스크림의 갯수는 '"+cnt+"' 개 입니다.");
		//return cnt;
	}
	
	// 체크박스 클릭 시 호출되는 함수
	function actionChoice(obj){
		// 확인
		// alert("함수 호출 확인");
		//alert("체크되어 있는지 확인");
		// alert(obj);
		//--==>> [object HTMLInputElement]
		//alert(obj.checked);
		//--==>> true/false
		//-- 체크 설정되며 클릭된 상황 → true 	┐
		//-- 체크 해제되며 클릭된 상황 → false ┘판단 가능
		
		
		if(obj.checked){		//-- 체크 설정 시
			if(userCnt >= cnt){
				alert("선택할 수 있는 갯수를 초과하였습니다.");
				
				// check 
				obj.checked = false;
				return;
			}
			//사용자가 선택한 아이스크림의 갯수 증가
			userCnt++;
		}else{					//-- 체크 해제 시
			//사용자가 선택한 아이스크림의 갯수 감소
			userCnt--;
		}
		
		// 확인
		//alert("선택 갯수: " + userCnt);
		alert("선택 가능: "+cnt+" / 선택 갯수: "+userCnt);
		
		
	}
	
