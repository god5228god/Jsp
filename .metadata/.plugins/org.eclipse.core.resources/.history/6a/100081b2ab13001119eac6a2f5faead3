<%@ page contentType="text/html; charset=UTF-8"%>
<%
	StringBuffer sb = new StringBuffer();
	sb.append("<ul>");
	for(int i = 1; i<=9; i++)
	{
		sb.append("<li>" + 5  + " × " + i + " = " + (5*i) + "</li>");
	}
	sb.append("</ul>");

%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>JspTest010.jsp</title>
<link rel="stylesheet" type="text/css" href="css/main.css" />
<style type="text/css">
	li{list-style: none;}
</style>
</head>
<body>

<div>
	<h1>JSP 기초</h1>
	<hr />
</div>

<!-- 
	○ 스크립릿 / 표현식 실습
	- 구구단 중에서 5단을 출력하는 JSP 페이지를 구현한다.
	- 요청 주소는
		http://localhost:3306/WebApp05/JspTest010.jsp로 한다.
	- 반복문을 활용한다.
 -->

<div><%= sb %></div>
<div><%= sb.toString() %></div>
</body>
</html>