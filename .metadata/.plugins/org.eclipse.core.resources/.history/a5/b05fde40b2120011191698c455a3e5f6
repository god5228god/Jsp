let menu = document.getElementById("menuTable");

function actionShow()
{
	let menuStatus = menu.getAttribute("display");
	if(menuStatus == "none"){		
		menu.style.display = "block";
	}
}

function actionHide()
{
	
	let menuStatus = menu.getAttribute("display");
	if(menuStatus == "block"){		
		menu.style.display ="none";
	}
	
	
}