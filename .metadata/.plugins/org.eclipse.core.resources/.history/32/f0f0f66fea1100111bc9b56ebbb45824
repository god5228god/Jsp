		 	<label for="b2">엄마는외계인</label><br>
		 	<input type="checkbox" name="checkGroup" id="c2" value="체리" onclick="actionChoice(this)"/>
		 	<label for="c2">체리쥬빌레</label><br>
		 	<input type="checkbox" name="checkGroup" id="d2" value="봉봉" onclick="actionChoice(this)"/>
		 	<label for="d2">아몬드봉봉</label><br>
		 	<input type="checkbox" name="checkGroup" id="e2" value="사랑" onclick="actionChoice(this)"/>
		 	<label for="e2">사랑에빠진딸기</label><br>
		 	<input type="checkbox" name="checkGroup" id="f2" value="바람" onclick="actionChoice(this)"/>
		 	<label for="f2">바람과함께사라지다</label><br>
		 	<input type="checkbox" name="checkGroup" id="g2" value="레인" onclick="actionChoice(this)"/>
		 	<label for="g2">레인보우샤베트</label><br>
		 	<input type="checkbox" name="checkGroup" id="h2" value="요거" onclick="actionChoice(this)"/>
