<%@ page import="java.util.Calendar" %>
<%@ page contentType="text/html; charset=UTF-8"%>
<%
	// 이전 페이지(SendAndReceive11_1.jsp)로부터 넘어온 데이터 수신
	//-- year, month
	
	String sYear = request.getParameter("year");
	String sMonth = request.getParameter("month");
	
	// Calendar 객체 생성
	//java.util.Calendar cal = java.util.Calendar.getInstance();
	Calendar cal = Calendar.getInstance();
	
	// 현재의 연, 월. 일 확인
	int nowYear = cal.get(Calendar.YEAR);			//-- 2026
	int nowMonth = cal.get(Calendar.MONTH) + 1 ; 	//-- 3
	int nowDay = cal.get(Calendar.DAY_OF_MONTH);	//-- 4
	
	// 표시할 달력의 연, 월 구성
	// → 페이지 최초 요청을 감안한 코드 처리
	int selectYear = nowYear;
	int selectMonth = nowMonth;
	
	// 페이지에 대한 요청이 최초 요청이 아닐 경우
	// → 선택한 값(이전 페이지로부터 수신한 값)을 활용한 달력의 연, 월 구성
	if(sYear != null || sMonth !=  null)
	{
		selectYear = Integer.parseInt(sYear);
		selectMonth = Integer.parseInt(sMonth);
	}
	
	// 테스트
	// out.print("<h1>selectYear: "+ selectYear + "</h1>");
	// out.print("<h1>selectMonth: "+ selectMonth + "</h1>");
	
	// 확인한 날짜로 연도 select option 구성
	//------------------------------------------------
 	// <option value="2016">2016</option>
	// <option value="2017">2017</option>
	// <option value="2018">2018</option>
	// 
	// <option value="2026" selected="selected">2026</option>
	// 				:
	// <option value="2034">2034</option>
	// <option value="2035">2035</option>
	// <option value="2036">2036</option> 
	//------------------------------------------------
	
	String yOption = "";
	for (int year=(selectYear-10); year<=(selectYear+10); year++)	// 2016 ~ 2036
	{
		// 관찰 ⓐ
		// yOption += "<option value='" +year +"'>"+year+"</option>";
		
		// 관찰 ⓑ
/* 		if(year==nowYear){
			yOption += "<option value='" +year +"' selected='selected'>"+year+"</option>";
		}else{
			yOption += "<option value='" +year +"'>"+year+"</option>";
		} */

		// 상황 1: 페이지 최초 요청일 때 → sYear는 null
		//		   현재의 연도와 옵션 값이 같을 때 
		// ==> selected(○)
		
		// 상황 2: 페이지 최초 요청이 아닐 때 → sYear는 null이 아님
		//		   선택된 연도와 옵션 값이 같을 때
		// ==> selected(○)
		
		// 상황 3: 나머지
		// ==> selected(×)
		
		if(sYear==null && year==nowYear)
			yOption += "<option value='" +year +"' selected='selected'>"+year+"</option>";
		else if(sYear!=null && year==Integer.parseInt(sYear))
			yOption += "<option value='" +year +"' selected='selected'>"+year+"</option>";
		else
			yOption += "<option value='" +year +"'>"+year+"</option>";
	}
	// 확인한 날짜로 월 select option 구성
	//------------------------------------------------
 	// <option value="1">1</option>
	// <option value="2">2</option>
	// <option value="3" selected="selected">3</option>
	// 				:
	// <option value="10">10</option>
	// <option value="11">11</option>
	// <option value="12">12</option>
	//------------------------------------------------
	
	String mOption = "";
	for(int month = 1; month<=12; month++)
	{
		// 상황 1: 페이지 최초 요청일 때 → sMonth는 null
				//		   현재의 월과 옵션 값이 같을 때 
				// ==> selected(○)
				
				// 상황 2: 페이지 최초 요청이 아닐 때 → sMonth는 null이 아님
				//		   선택된 월과 옵션 값이 같을 때
				// ==> selected(○)
				
				// 상황 3: 나머지
				// ==> selected(×)
		if(sMonth==null && month==nowMonth)
			mOption += "<option value='" +month +"' selected='selected'>"+month+"</option>";
		else if(sMonth!=null && month==Integer.parseInt(sMonth))
			mOption += "<option value='" +month +"' selected='selected'>"+month+"</option>";
		else
			mOption += "<option value='" +month +"'>"+month+"</option>";
	}

	// 그려야 할 달력의 1일이 무슨 요일인지 확인 필요
	// (만년 달력 구조)
	
	int[] months = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};	//-- 각 월의 최대 날짜
	if(selectYear%4==0 && selectYear%100!=0 || selectYear%400==0)	//-- 윤년
		months[1] = 29;
	
	// 총 날 수 누적 변수
	int nalsu;
	
	// 요일 항목 타이블 배열 구성
	String[] weekNames = {"일요일", "월요일", "화요일", "수요일", "목요일", "금요일", "토요일"};
	
	// 입력받은 연도 이전 년도까지의 날 수 계산
	nalsu = (selectYear-1)*365 + (selectYear-1)/4 - (selectYear-1)/100 + (selectYear-1)/400;
	
	// 위 계산 항목에 입력받은 월의 이전 월까지의 날 수 추가
	for(int i=0; i<selectMonth-1; i++){
		nalsu += months[i];
	}
	
	nalsu++;								//-- + 1 (1일까지의 날짜 합산)
	
	int week = nalsu%7;						//-- 요일 변수
	int lastDay = months[selectMonth-1];	//-- 해당 월의 마지막 날짜 변수
	
	// 달력 그리기 ---------------------------------------------------------------------
	String calStr = "";
	
	calStr += "<table border='1'>";
	calStr += "<tr>";
	for(int i = 0 ; i<weekNames.length;i++)
	{
		// 확인
		//calStr += "<th>" + weekNames[i] + "</th>";
		
		if(i==0)															//-- 일요일
			calStr += "<th class='sun'>" + weekNames[i] + "</th>";
		else if(i==6)														//-- 토요일
			calStr += "<th class='sat'>" + weekNames[i] + "</th>";
		else
			calStr += "<th>" + weekNames[i] + "</th>";
	}
	
	calStr += "</tr>";
	
	// 빈 칸 공백 td 발생
	calStr += "<tr>";
	for(int i = 1 ; i<=week;i++)
		calStr +="<td></td>";
	
	// 날짜 td 발생
	for(int i = 1; i<=lastDay; i++)
	{
		week++;							//-- 날짜가 하루씩 처리될 때마다(구성이 이루어질 때 마다)
										//	 요일도 함께 1씩 증가될 수 있도록 처리 CHECK!
		// 확인
		//calStr +="<td>"+i+"</td>";
		
		// 오늘 날짜 확인
		// nowYear, nowMonth, nowDay
		nowDay = 7;
		if(selectYear==nowYear&& selectMonth==nowMonth&& i==nowDay)
		{
			
			if(week%7==1){
				calStr +="<td class='nowSun'>"+i+"</td>";
			}else if(week%7==6){
				calStr +="<td class='nowSat'>"+i+"</td>";
			}else{
				calStr +="<td class='now'>"+i+"</td>";
			}
		}else{
			calStr +="<td>"+i+"</td>";
		}
		
		
		if(week%7==0)
			calStr += "</tr><tr>";
	}
	calStr += "</tr>";
	calStr += "</table>";
	
	
	//---------------------------------------------------------------------- 달력 그리기
	
%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>SendAndReceive11_1.jsp</title>
<link rel="stylesheet" type="text/css" href="css/main.css" />
<style type="text/css">
table{border-collapse: collapse;}
tr>*{text-align: center; padding: 5px;}
td.now{background-color: aqua; font-weight: bold;}
.sat{color: blue;}
.sun{color: red;}
td.nowSat{background-color: aqua; font-weight: bold; color: blue;}
td.nowSun{background-color: aqua; font-weight: bold; color: red;}

</style>
<script type="text/javascript">
	function formCalendar(obj)
	{
		// 유효성 검사가 필요할 경우 삽입할 수 있는 영역
		obj.submit();
		//-- obj → form 객체
	}
</script>
</head>
<body>
<div>
	<h1>JSP를 이용한 데이터 송수신 실습 11</h1>
	<p>SendAndReceive11_1.jsp● → SendAndReceive11_1.jsp●</p>
	<hr />
</div>

<!-- 
	○ 데이터 송수신 실습
	
	  - 연도와 월을 입력받아 해당 연월의 달력을 화면에 출력하는 JSP 페이지를 구성한다.
	  
	  - 단, submit 버튼 없이 이벤트 처리를 할 수 있도록 한다.
	  
	  - 전송한 내용을 수신하여 출력해주는 형태의 페이지로 구성한다.
	  
	  - 연도 구성은 현재 연도를 기준으로 이전 10년, 이후 10년으로 구성한다.
	    (기본적으로 만년 달력을 구성하는데, 현재의 연, 월을 달력 객체를 활용할 수 있도록 한다.)

	  - 월 구성은 1월부터 12월까지로 한다.
	  
	  페이지 레이아웃
	  ---------------------------------------------
	   2016			 1	
	  	 :			 :
	  [2026 ▼] 년 [ 3 ▼] 월
	  	 :			 :
	   2036			12
	  
	  
	  ----------------------------
	  ---- 해당 년 월의 달력 -----
	  ----------------------------
	  ----------------------------
	  
	  ---------------------------------------------
	  
	  - 연도 select나 월 select의 내용이 변화되면
	    해당 연 월의 달력을 출력하주는 형태의 페이지로 구성한다.
	    
	    - 사용자 최초 요청 주소
	      http://localhost:3306/WebApp06/SendAndReceive11.jsp
	      
	   - 물리적 파일 구성
	     ·SendAndReceive11.jsp
	
 -->


<!-- 
	1. submit 액션 처리 → 스크립트 제어
	
	2. 수신한 데이터에 대한 처리(이전 페이지로부터 데이터 수신)
	   → 연도, 월
	   
	3. Calendar 객체 생성
	   → 현재의 연, 월, 일 확인
	   
	4. 표시할 달력의 연, 월 구성
	   → 페이지 최초 요청을 감안한 코드 처리 필요
	   	  (연도 select, 월 select)
	   	  
	5. 페이지에 대한 요청이 최초 요청이 아닐 경우
	   → 사용자가 선택한 값을 활용한 달력의 연, 월 구성
	   
	6. 해당 연, 월의 달력 그리기
 -->

<div>
	<!-- ※ form의 action 속성 또는 action 속성값 생략
			→ 요청 페이지/ 전송 데이터의 수신처는 자기 자신
	-->
	<form method="post">
		<select name="year" id="year" onchange="formCalendar(this.form)">
		
		<!-- 	<option value="9999">9999</option>
			<option value="9998">9998</option>
			<option value="9997">9997</option>
			<option value="9996">9996</option> -->
			<%= yOption %>
			
		</select> 년
		<select name="month" id="month" onchange="formCalendar(this.form)">
<!-- 			<option value="99">99</option>
			<option value="98">98</option>
			<option value="97">97</option>
			<option value="96">96</option> -->
			<%= mOption %>
		</select> 월
	</form>
</div>
<br><br>

<div>
	달력을 그리게 될 지점
	<%= calStr %>
</div>























</body>
</html>