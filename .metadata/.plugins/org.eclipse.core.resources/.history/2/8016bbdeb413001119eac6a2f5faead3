<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Send01.html</title>
<link rel="stylesheet" type="text/css" href="css/main.css" />
</head>
<body>
<!-- 
	○ 데이터 송수신 실습
	
	- 이름과 전화번호를 입력받는 html 페이지를 구성한다.
	
		이름 	 [ textbox	] 	← 조세빈
		전화번호 [	textbox	] 	← 010-1111-1111
		
		< 회원 가입> 			→ button
		
	- 회원 가입 버튼 클릭 시
		『조세빈님, 회원 가입이 완료되었습니다.
		  회원님께서 등록하신 전화번호는 010-1111-1111 입니다.』
	  라는 내용을 출력하는 JSP 페이지를 전달할 수 있도록 한다.
	  
	- 사용자 최초 요청 주소
		http://localhost:3306/WebApp06/Send01.html
		
	- 물리적 파일 구성
	 · Send01.html
	 · Receive01.jsp
 -->
 <div>
 	<h1>회원 가입</h1>
 	<hr />
 </div>
 <div>
 	<!-- 1. 클라이언트 측에서 서버 측에 데이터를 전송하기 위해 form 태그 필요 -->
 	<!-- 2. form 태그 영역 안에 들어가야 할 대상은 이름과 전화번호 submit -->
 	<!-- 3. form의 action 속성은 데이터를 전송하며 요청하는 JSP 페이지의 주소 지정 -->
 	<!-- 4. form의 method 속성은 데이터 전송 및 페이지 요청 방식 지정 -->
 	<!-- → get 또는 post -->
 	<!-- <form action="/WebApp06/Receive01.jsp" method="get"> --><!-- 이렇게 해도 되고 -->
 	<form action="Receive01.jsp" method="get">					 <!-- 이렇게 해도 된다. -->
 		<table>
 			<tr>
 				<th>이름</th>
 				<td>
 					<!-- 6. id, name, class 속성 등은  -->
 					<!-- 	어떤 영역에서 어떤 선택자로 활용할 지에 따라 -->
 					<!-- 	적절히 계획해서 부여해야 한다.  -->
 					<!-- 7. name 속성은 JSP에서 주로 사용할 식별자 -->
 					<input type="text" id="userName" name="userName" placeholder="ex)홍길동" class="txt"/>
 				</td>
 			</tr>
 			<tr>
 				<th>전화번호</th>
 				<td>
 					<input type="text" id="userTel" name="userTel" placeholder="ex)010-1111-1111" class="txt"/>
 				</td>
 			</tr>
 			<tr style="height: 50px;">
 				<td colspan="2">
 					<!-- 5. 『submit』을 통해 전송 및 요청 기능을 수행할 수 있다. --> 
 					<!-- 	『<input type="submit" value="회원 가입" />』과 동일한 코드지만 -->
 					<!--  	『<button>』은 이미지 또는 다른 태그들을 넣을 수 있는 구조이며,-->
 					<!-- 『<input>』은 스타일 구성을 폭넓게 할 수 있는 편이다. -->
 					<button type="submit" class="btn">회원 가입</button>
 					<button type="reset" class="btn">취소</button>
 				</td>
 			</tr>
 		</table>
 		
 	</form>
 </div>
</body>
</html>