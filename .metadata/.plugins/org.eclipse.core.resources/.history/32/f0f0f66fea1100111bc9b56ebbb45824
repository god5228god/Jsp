<style type="text/css">
form{position: relative; width: 600px; height: 600px; 
	background-color: #ebf2ff; padding: 20px 10px; box-sizing: border-box;}
.btn{margin: 20px 0;width: 100px; height: 40px; 
	font-size: 18px; border: none;  background-color: #F20C90; 
		color: #fff; font-weight: bold; position: absolute; bottom: -10px; left: 250px;}
.btn:hover{background-color: #fff; color: #07219B; border: 3px solid #07219B;}
h2{font-size: 30px; font-weight: bold; color: #f20c90; width: 600px; text-align: center;}
p{font-size: 25px; font-weight: bold; width: 600px; text-align: center; margin: 0; margin-bottom: 15px; color: #07219B;}
.checkWrap{width: 200px; height: 350px;  margin: 0 auto; position: relative;}
.checkWrap>*{margin-bottom: 10px;}

input[type="checkbox"] {
    appearance: none; /* 기본 모양 삭제 */
    width: 15px;
    height: 15px;
    border: 2px solid #ccc;
    cursor: pointer;
  	position: relative; top: 12px;
  	background-color: #fff;
}

input[type="radio"] {
    appearance: none; /* 기본 모양 삭제 */
    width: 18px;
    height: 18px;
    border: 2px solid #ccc;
    border-radius: 50%;
    cursor: pointer;
  	position: relative; top: 2px;
  	background-color: #fff;
}


input[type="checkbox"]:checked, input[type="radio"]:checked {
    color: #f20c90;
    background-color: #F20C90;
    border: 2px solid #ccc;
}
input[type="checkbox"]:checked + label{color: #f20c90; font-weight: bold;}
input[type="radio"]:checked + label{color: #f20c90; font-weight: bold;}
}

</style>
