		 	<input type="checkbox" name="checkGroup" id="i2" value="슈팅" onclick="actionChoice(this)"/>
		 	<label for="i2">슈팅스타</label><br>
		 	<input type="checkbox" name="checkGroup" id="j2" value="베리" onclick="actionChoice(this)"/>
		 	<label for="j2">베리베리스트로베리</label><br>
		 	<input type="checkbox" name="checkGroup" id="k2" value="애플" onclick="actionChoice(this)"/>
		 	<label for="k2">애플민트</label><br>
		</div>
		
		<button type="button" class="btn" >선택 완료</button>
	</form>
