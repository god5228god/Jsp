<%

	//이전 페이지(Send07.jsp)로부터 넘어온 데이터 수신

	String num1Str = request.getParameter("su1");
	String num2Str = request.getParameter("su2");
	
	int num1 = 0;
	int num2 = 0;
	
	int multiple = 0;
	
	try
	{
		 num1 = Integer.parseInt(num1Str);
		 num2 = Integer.parseInt(num2Str);
		

		
	}catch(Exception e)
	{
