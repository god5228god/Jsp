<%@ page contentType="text/html; charset=UTF-8"%>
<%
	int num = 970;

	int m500 = num/500;
	int m100 = (num%500)/100;
	int m50 =  (num%100)/50;
	int m10 =  (num%50)/10;
	
	StringBuilder sb = new StringBuilder();
	
	sb.append("대상 금액: " + num + "원 <br>");
	sb.append("화폐 단위: 오백원 " + m500 + ", 백원 " + m100 + ", 오십원 " + m50 + ", 십원 " + m10);
%>
<%
	// 스크립 영역
	 
	int money, initMoney;
	money = initMoney = 970;
	int m500 = 0, m100 = 0, m50 =0, m10 = 0;
	
	

%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>JspTest011.jsp</title>
<link rel="stylesheet" type="text/css" href="css/main.css" />
</head>
<body>
<div>
	<h1>JSP 기초</h1>
	<hr />
</div>
<!-- 
	○ 스크립릿 / 표현식 활용 실습
	- 임의의 금액 (→ 970원)을 화폐 단위로 구분하여 출력하는
		JSP 페이지를 구현한다.
	- 요청 주소는
		http://localhost:3306/WebApp05/JspTest011.jsp로 한다.
	
	- 실행 예
	
