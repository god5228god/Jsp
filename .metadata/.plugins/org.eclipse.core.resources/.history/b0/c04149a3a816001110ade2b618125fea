<%@ page contentType="text/html; charset=UTF-8"%>
<%
	
	request.setCharacterEncoding("UTF-8");

	String name = request.getParameter("name");
	char genderCh = request.getParameter("gender").charAt(0);
	String major = request.getParameter("major");
	String[] hobbies = request.getParameterValues("hobby");
	String gender = "";

	try
	{
		if(genderCh=='M'){
			gender = "M(남자)";
		}else{
			gender = "F(여자)";
		}
		
	}
	catch(Exception e)
	{
		System.out.println(e.toString());
	}

%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Receive05.jsp</title>
<link rel="stylesheet" type="text/css" href="css/main.css" />
</head>
<body>
<div>
	<h1>JSP를 이용한 데이터 송수신 실습 04</h1>
	<p>Send05.jsp ○ → Receive05.jsp ●</p>
	<hr />
</div>
<div>
	<h2>결과확인</h2>
	
	<div>
		<p>이름: <span><%= name %></span></p>
		<p>성별: <span><%= gender %></span></p>
		<p>전공: <span><%= major %></span></p>
		<p>취미: <span><%= hobbies %></span></p>
	</div>
</div>
</body>
</html>