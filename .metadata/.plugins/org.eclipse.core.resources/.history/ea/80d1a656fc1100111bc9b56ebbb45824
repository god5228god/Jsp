	function addMember()
	{
		
		let name = document.getElementById("userName").value;
		let ssn = document.getElementById("userSsn").value;
		let basicPay = document.getElementById("userBasicpay").value;
		
		let cityObj = document.getElementById("userCity");
		let departmentObj = document.getElementById("userDepartment");
