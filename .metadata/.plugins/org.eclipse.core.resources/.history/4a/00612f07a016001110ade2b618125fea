<%@ page contentType="text/html; charset=UTF-8"%>
<%
	// 스크립릿 영역
	// ※ 넘어온 데이터에 한글이 포함되어있지 않으므로 
	// request.setCharacterEncoding("UTF-8");
	// 이 코드는 생략 가능
	
	// 이전 페이지로(Send03.html)부터 넘어온 데이터 수신
	//-- int01, int02, operator

	String num1 = request.getParameter("int01");
	String num2 = request.getParameter("int02");
	String op = request.getParameter("operator");
	
	// double result = 0;
	String result = "";
	
	try
	{
		int n1 = Integer.parseInt(num1);
		int n2 = Integer.parseInt(num2);
		
		if(op.equals("+")){
			result = String.valueOf(n1+n2);
		}else if(op.equals("-")){
			result = String.valueOf(n1-n2);
		}else if(op.equals("*")){
			result = String.valueOf(n1*n2);
		}else{
			//result = String.valueOf(n1/n2);
			//result = String.valueOf(n1/(double)n2);
			result = String.format("%.1f", n1 / (double)n2);
		}
		
		
	}catch(Exception e)
	{
		// 예외 발생 시
		// 클라이언트의 브라우저 화면에 출력되지 않고
		// 서버의 콘솔 창에 오류메시지가 나오도록 구성하는 코드
		System.out.println(e.toString());
		
		// 예외 발생 시
		// 해당 내용으로 서버 log 기록으로 남기는 처리
		getServletContext().log("오류 :" + e.toString());
	}
	
	
	
%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
<link rel="stylesheet" type="text/css" href="css/main.css" />
<style type="text/css">
span{color: red}
</style>
</head>
<body>
<div>
	<p>입력하신 <span><%= num1 %></span>과(와) <span><%= num2 %></span>의 연산 결과는
		<span><%=result %>입니다.</span></p>
</div>
</body>
</html>