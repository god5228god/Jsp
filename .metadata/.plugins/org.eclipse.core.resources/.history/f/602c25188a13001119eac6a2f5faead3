@charset "UTF-8";

*
{
	color: #223322;
	font-family: 나눔고딕코딩;	
}

body, p, div, span, input, table, th, td, select
{
	font-size: 18px;
}

.control
{
	border: 1px solid gray;
	border-radius: 3px ;
}

.table
{
	border-collapse: collapse;
	width: 100%;
}

.table th, .table td
{
	border: 1px solid gray;
	border-left: 0;
	border-right: 0;
	padding: 3px;
	line-height: 150%;
}

.table th
{
	font-weight: bold;
	background-color: #eee;
}

.btn
{
	font-weight: bold;
	font-family: 맑은 고딕;
	border: none;
	
}

.btn:hover
{
	color: #fff;
	background-color: #778877;
}
input[type="text"]:focus
{
	background-color: #dcfccf;
}












